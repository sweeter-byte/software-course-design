# Copy this file to .env.local and fill in real values.

# MySQL connection (run `sudo mysql < scripts/setup-mysql.sql` once to provision).
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=course_app
MYSQL_PASSWORD=replace-with-your-course_app-password
MYSQL_DATABASE=course_manage_system
MYSQL_TEST_DATABASE=course_manage_system_test

# CloudBase verification.
VERIFICATION_PROVIDER=cloudbase
CLOUDBASE_API_BASE_URL=https://your-env-id.api.tcloudbasegateway.com
CLOUDBASE_API_TOKEN=replace-with-your-cloudbase-api-token
