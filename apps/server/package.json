{
  "name": "@course/server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json && node scripts/write-dist-package-json.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/apps/server/src/index.js",
    "seed": "tsx src/lib/db/seed-cli.ts",
    "db:reset": "tsx src/lib/db/reset.ts"
  },
  "dependencies": {
    "@fastify/cors": "latest",
    "@fastify/jwt": "latest",
    "bcryptjs": "latest",
    "fastify": "latest",
    "mysql2": "^3.22.3",
    "nanoid": "latest",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "latest",
    "tsx": "latest",
    "typescript": "~5.9.2",
    "vitest": "latest"
  }
}
